#include <stdlib.h>
#include <stdio.h>
#include <time.h>
#include <string.h>

typedef struct {
    char name[50];
    int age;
} Person;

int main(void) {

    Person sue;
    strncpy(sue.name, "Sue", sizeof(sue.name));
    sue.age = 30;
    printf("\n");
    printf("Name: %s, Age: %d\n", sue.name, sue.age);

    // Allocate memory for 20 integers
    int *arr = (int *)malloc(20 * sizeof(int));
    
    if (arr == NULL) {
        printf("Memory allocation failed\n");
        return 1;
    }
    
    // Seed the random number generator
    srand(time(NULL));
    
    // Assign random values to each location
    for (int i = 0; i < 20; i++) {
        arr[i] = rand() % 101;
        printf("arr[%d] = %d\n", i, arr[i]);
    }
    
    // Free the allocated memory
    free(arr);
    
    return 0;
}
